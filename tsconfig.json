{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "declaration": true,
    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",

    "incremental": true,
    "skipLibCheck": true,

    /* =========================
       🔐 STRICTNESS (IMPORTANT)
    ========================= */
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,

    /* =========================
       PATH ALIASES
    ========================= */
    "paths": {
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@files/*": ["src/files/*"],
      "@folders/*": ["src/folders/*"],
      "@upload/*": ["src/upload/*"],
      "@otp/*": ["src/otp/*"],
      "@transactions/*": ["src/transactions/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@r2/*": ["src/r2/*"]
    }
  }
}